# Air Haifa / GO7 AeroCRS
AEROCRS_ENTITY=
AEROCRS_TOKEN=
AEROCRS_PASSWORD=
AEROCRS_BASE_URL=https://api.aerocrs.com

# El Al / Duffel
DUFFEL_ACCESS_TOKEN=
DUFFEL_ENV=live

# Arkia (placeholder — requires Radixx ConnectPoint contract)
ARKIA_ENABLED=false

# Israir (placeholder — requires Amadeus access)
ISRAIR_ENABLED=false

# Slack
SLACK_MODE=webhook
SLACK_WEBHOOK_URL=
SLACK_BOT_TOKEN=
SLACK_CHANNEL_ID=

# Scheduler
POLL_INTERVAL_MINUTES=5
POLL_HOURS_START=6
POLL_HOURS_END=22
TIMEZONE=Asia/Jerusalem

# Dedup
DEDUP_COOLDOWN_MINUTES=45

# Logging
LOG_LEVEL=info
